{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/index.js" },
        { "src": "/(.*\\.(js|css|html|ico|png|jpg|svg))", "dest": "/frontend/$1" },
        { "src": "/", "dest": "/frontend/index.html" }
    ]
}
